# ========== 百度语音服务(必填) ==========
# 申请地址: https://console.bce.baidu.com/ai/#/ai/speech/overview/index
BAIDU_APP_ID=你的百度AppID
BAIDU_API_KEY=你的百度APIKey
BAIDU_SECRET_KEY=你的百度SecretKey

# ========== 大模型(必填，兼容 OpenAI 接口格式) ==========
# 智谱: https://open.bigmodel.cn/  |  DeepSeek: https://platform.deepseek.com/
# 通义千问: https://dashscope.aliyun.com/  |  硅基流动: https://siliconflow.cn/
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=你的大模型APIKey
LLM_MODEL_NAME=glm-4.7-flash
SYSTEM_PROMPT=你是一个亲切自然的虚拟助手，用简洁口语化的中文回答，回复控制在100字以内。

# ========== 服务配置(可选) ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
